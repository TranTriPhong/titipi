---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Search from '../components/Search';

// Lấy tất cả bài viết từ collection knowledge
const knowledgePosts = await getCollection('knowledge');

// Sắp xếp bài viết mới nhất lên đầu
knowledgePosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Knowledge Hub | titipi." lang="vi">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <header class="mb-16 border-b border-black/10 dark:border-white/10 pb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-black dark:text-white mb-6 tracking-tight">
        Knowledge Hub
      </h1>
      <p class="text-lg text-black/60 dark:text-white/60 leading-relaxed border-l-2 border-emerald-500 pl-4 mb-8">
        Trung tâm lưu trữ kiến thức. Nơi ghi chép lại các thuật toán, tư duy logic, toán học và kiến trúc hệ thống.
      </p>
      
      {/* Search Component (Island) */}
      <Search client:load allPosts={knowledgePosts} />
    </header>

  </div>
</BaseLayout>