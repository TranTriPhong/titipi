---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Lọc lấy tất cả các bài viết trong thư mục projects có category là "tool"
const securityPosts = await getCollection('projects', ({ data }) => data.category === 'tool');

// Sắp xếp bài viết mới nhất lên đầu
securityPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Security Lab | titipi." lang="vi">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <header class="mb-16 border-b border-black/10 dark:border-white/10 pb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-black dark:text-white mb-6 tracking-tight">
        Security Lab
      </h1>
      <p class="text-lg text-black/60 dark:text-white/60 leading-relaxed border-l-2 border-emerald-500 pl-4">
        Phòng thí nghiệm an toàn thông tin. Nơi phân tích chuyên sâu các kỹ thuật tấn công, lỗ hổng hệ thống và phương pháp phòng thủ.
        <br/><span class="italic text-sm mt-2 block opacity-80">*Lưu ý: Nội dung chỉ phục vụ mục đích giáo dục và nghiên cứu học thuật.*</span>
      </p>
    </header>

    <div class="grid grid-cols-1 gap-6">
      {securityPosts.map((post) => (
        <a href={`/projects/${post.id}`} class="group p-6 rounded-2xl border border-black/10 dark:border-white/10 hover:border-emerald-500 dark:hover:border-emerald-500 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/5 dark:hover:shadow-white/5 transition-all duration-300 flex flex-col sm:flex-row sm:items-center justify-between gap-6 bg-black/[0.02] dark:bg-white/[0.02]">
          <div class="flex-1">
            <h3 class="text-xl font-bold text-black dark:text-white mb-2 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">{post.data.title}</h3>
            <p class="text-sm text-black/60 dark:text-white/60 leading-relaxed line-clamp-2">{post.data.description}</p>
          </div>
          <div class="flex flex-col sm:items-end gap-3 min-w-[120px]">
            <span class="text-xs font-mono text-black/40 dark:text-white/40 border border-black/10 dark:border-white/10 px-2 py-1 rounded-md">
              {post.data.publishDate.toISOString().split('T')[0]}
            </span>
            <span class="text-[10px] font-extrabold uppercase tracking-widest text-emerald-500 group-hover:translate-x-1 transition-transform">
              Read ↗
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>