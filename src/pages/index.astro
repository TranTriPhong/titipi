---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Tự động kéo dữ liệu từ kho ra
const featuredKnowledge = await getCollection(
  "knowledge",
  ({ data }) => data.featured === true,
);
const featuredStudents = await getCollection(
  "students",
  ({ data }) => data.featured === true,
);
---

<BaseLayout title="Trang Chủ" lang="vi">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    <!-- HERO SECTION -->
    <section class="mb-24">
      <h1
        class="text-5xl md:text-7xl font-black text-black dark:text-white mb-8 tracking-tighter leading-none"
      >
        Hi, welcome to my website.
      </h1>
      <p
        class="text-xl md:text-2xl text-black/60 dark:text-white/60 leading-relaxed font-medium max-w-2xl"
      >
        I am Phong, and this website is a place where I share my knowledge,
        projects, and thoughts with the world.
      </p>
    </section>

    <!-- ABOUT ME -->
    <section class="mb-24">
      <h2
        class="text-xs font-bold text-black/40 dark:text-white/40 uppercase tracking-[0.2em] mb-8 border-b border-black/10 dark:border-white/10 pb-4"
      >
        About Me
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <p class="text-lg text-black/70 dark:text-white/70 leading-relaxed">
          My journey started with a fascination for algorithmic thinking—I even
          spent some time mentoring students for the VOI. That foundation
          eventually led me straight into the world of Pentest and Reverse
          Engineering.
        </p>
        <p class="text-lg text-black/70 dark:text-white/70 leading-relaxed">
          I’m a firm believer in self-paced learning, usually found building
          labs with Docker and Kali, and meticulously documenting every "Aha!"
          moment in my Obsidian vault. This space is where I share the process,
          the roadmaps, and the research findings along the way.
        </p>
      </div>
    </section>

    <!-- PERSONAL PROJECTS -->
    <section id="projects" class="mb-24">
      <h2
        class="text-xs font-bold text-black/40 dark:text-white/40 uppercase tracking-[0.2em] mb-8 border-b border-black/10 dark:border-white/10 pb-4"
      >
        Personal Projects
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Personal Security Lab -->
        <div
          class="group p-8 rounded-3xl border border-black/10 dark:border-white/10 bg-black/[0.01] dark:bg-white/[0.01] hover:border-emerald-500 transition-all"
        >
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path></svg
              >
            </div>
            <h3 class="text-xl font-bold text-black dark:text-white">
              Personal Security Lab
            </h3>
          </div>
          <p class="text-sm text-black/60 dark:text-white/60 leading-relaxed">
            My digital playground where I simulate attack scenarios and test
            defenses. It taught me that breaking things is often the best way to
            understand how to fix them.
          </p>
        </div>

        <!-- Portfolio -->
        <div
          class="group p-8 rounded-3xl border border-black/10 dark:border-white/10 bg-black/[0.01] dark:bg-white/[0.01] hover:border-blue-500 transition-all"
        >
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-500"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"
                ></path><path d="m14.5 4-5 16"></path></svg
              >
            </div>
            <h3 class="text-xl font-bold text-black dark:text-white">
              This Portfolio
            </h3>
          </div>
          <p class="text-sm text-black/60 dark:text-white/60 leading-relaxed">
            A small corner where I turn my Obsidian research notes into readable
            write-ups. It’s my way of keeping things organized and sharing
            knowledge with the community.
          </p>
        </div>
      </div>
    </section>

    <!-- KNOWLEDGE HUB PREVIEW -->
    <section id="knowledge" class="mb-24">
      <h2
        class="text-xs font-bold text-black/40 dark:text-white/40 uppercase tracking-[0.2em] mb-8 border-b border-black/10 dark:border-white/10 pb-4"
      >
        Knowledge Highlights
      </h2>
      <div class="grid grid-cols-1 gap-4">
        {
          featuredKnowledge.map((k) => (
            <a
              href={`/knowledge/${k.id}`}
              class="group p-6 rounded-2xl border border-black/10 dark:border-white/10 hover:border-emerald-500 transition-all flex justify-between items-center bg-black/[0.01] dark:bg-white/[0.01]"
            >
              <div>
                <span class="text-[9px] font-black text-emerald-500 uppercase tracking-widest block mb-1">
                  {k.data.category}
                </span>
                <h3 class="text-xl font-bold text-black dark:text-white group-hover:text-emerald-500 transition-colors">
                  {k.data.title}
                </h3>
              </div>
              <span class="text-black/20 dark:text-white/20 group-hover:translate-x-1 transition-transform">
                →
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- STUDENTS SHOWCASE (Dự án học sinh) -->
    <section id="students" class="mb-24">
      <h2
        class="text-xs font-bold text-black/40 dark:text-white/40 uppercase tracking-[0.2em] mb-8 border-b border-black/10 dark:border-white/10 pb-4"
      >
        Students Showcase
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          featuredStudents.map((s) => (
            <div class="group p-6 rounded-2xl border border-black/10 dark:border-white/10 hover:border-emerald-500 dark:hover:border-emerald-500 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-black/5 dark:hover:shadow-white/5 transition-all duration-300 flex flex-col justify-between gap-6">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">
                    {s.data.studentName}
                  </span>
                  <span class="text-[10px] font-mono text-black/40 dark:text-white/40 border border-black/10 dark:border-white/10 px-2 py-0.5 rounded-md">
                    {s.data.age} tuổi
                  </span>
                </div>
                <h3 class="text-xl font-bold text-black dark:text-white mb-3 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
                  {s.data.title}
                </h3>
                <p class="text-sm text-black/60 dark:text-white/60 italic border-l-2 border-emerald-500 pl-3 py-1">
                  "{s.data.mentorNote}"
                </p>
              </div>
              <div class="flex flex-wrap gap-2">
                {s.data.techStack.map((tag) => (
                  <span class="text-[11px] font-mono text-black/70 dark:text-white/70 bg-black/5 dark:bg-white/10 px-2.5 py-1 rounded-full">
                    [{tag}]
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
