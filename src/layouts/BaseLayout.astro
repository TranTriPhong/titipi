---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';

const { title, lang = "vi" } = Astro.props;
---

<html lang={lang} class="scroll-smooth">
  
    
    <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>titipi.</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- 3. Script xử lý Dark Mode cực mạnh (Tự động + Real-time + Hỗ trợ Chuyển trang) -->
    <script is:inline>
      const applyTheme = () => {
        const getThemePreference = () => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };

        const isDark = getThemePreference() === 'dark';
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      };

      // Chạy ngay khi nạp trang đầu tiên
      applyTheme();

      // Quan trọng: Chạy lại mỗi khi sếp bấm chuyển trang để không bị mất Dark Mode
      document.addEventListener('astro:after-swap', applyTheme);

      // Theo dõi nếu sếp đổi theme trên hệ thống/điện thoại thì web đổi theo luôn
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        const newTheme = e.matches ? 'dark' : 'light';
        document.documentElement.classList[newTheme === 'dark' ? 'add' : 'remove']('dark');
        localStorage.setItem('theme', newTheme);
      });
    </script>
  </head>
  
  <body class="bg-white text-zinc-900 dark:bg-[#080808] dark:text-zinc-100 transition-colors duration-500 min-h-screen flex flex-col selection:bg-zinc-900 selection:text-white dark:selection:bg-white dark:selection:text-black font-sans relative">
    <!-- Clean Minimalist Background -->
    <div class="fixed inset-0 z-[-1] pointer-events-none opacity-[0.03] dark:opacity-[0.05]" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 40px 40px;"></div>
    
    <nav class="sticky top-0 z-[100] backdrop-blur-xl bg-white/80 dark:bg-[#080808]/80 border-b border-zinc-100 dark:border-white/5 transition-all">
