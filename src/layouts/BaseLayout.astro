---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';

const { title, lang = "vi" } = Astro.props;
---

<html lang={lang} class="scroll-smooth">
  
    
    <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>titipi.</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 3. Script xử lý Dark Mode cực mạnh (Tự động + Real-time + Hỗ trợ Chuyển trang) -->
    <script is:inline>
      const applyTheme = () => {
        const getThemePreference = () => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };

        const isDark = getThemePreference() === 'dark';
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      };

      // Chạy ngay khi nạp trang đầu tiên
      applyTheme();

      // Quan trọng: Chạy lại mỗi khi sếp bấm chuyển trang để không bị mất Dark Mode
      document.addEventListener('astro:after-swap', applyTheme);

      // Theo dõi nếu sếp đổi theme trên hệ thống/điện thoại thì web đổi theo luôn
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        const newTheme = e.matches ? 'dark' : 'light';
        document.documentElement.classList[newTheme === 'dark' ? 'add' : 'remove']('dark');
        localStorage.setItem('theme', newTheme);
      });
    </script>
  </head>
  
  <body class="bg-white text-black dark:bg-[#0a0a0a] dark:text-white transition-colors duration-300 min-h-screen flex flex-col selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black" style="font-family: 'Inter', sans-serif;">
    
