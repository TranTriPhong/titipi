---
// src/components/ChatAI.astro
---

<div id="ai-chat-root" class="fixed bottom-6 right-6 z-[999]">
  <!-- Floating Trigger Bubble -->
  <button
    id="ai-bubble-trigger"
    class="w-16 h-16 bg-gradient-to-tr from-emerald-600 to-emerald-400 text-white rounded-2xl shadow-[0_8px_32px_rgba(16,185,129,0.3)] flex items-center justify-center hover:scale-105 hover:-translate-y-1 active:scale-95 transition-all duration-300 group"
  >
    <div class="relative">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="group-hover:rotate-12 transition-transform duration-300"
      >
        <path d="M12 8V4H8"></path>
        <rect width="16" height="12" x="4" y="8" rx="2"></rect>
        <path d="M2 14h2"></path>
        <path d="M20 14h2"></path>
        <path d="M15 13v2"></path>
        <path d="M9 13v2"></path>
      </svg>
      <span class="absolute -top-1 -right-1 w-3 h-3 bg-white rounded-full animate-ping opacity-75"></span>
    </div>
  </button>

  <!-- Premium Chat Window (Glassmorphism) -->
  <div
    id="ai-window"
    class="hidden absolute bottom-20 right-0 w-[360px] md:w-[400px] max-h-[550px] bg-white/80 dark:bg-zinc-900/80 backdrop-blur-2xl rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.2)] border border-white/20 dark:border-white/10 overflow-hidden flex flex-col origin-bottom-right transition-all duration-300 scale-95 opacity-0"
  >
    <!-- Header -->
    <div class="p-5 bg-gradient-to-r from-emerald-500/10 to-transparent flex justify-between items-center border-b border-black/5 dark:border-white/5">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center text-white shadow-lg shadow-emerald-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">titipi AI</h4>
          <p class="text-[9px] text-black/40 dark:text-white/40 uppercase font-bold tracking-widest">Always Online</p>
        </div>
      </div>
      <button id="close-ai" class="p-2 hover:bg-black/5 dark:hover:bg-white/5 rounded-full transition-colors text-black/40 dark:text-white/40 hover:text-red-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
    </div>

    <!-- Chat Content -->
    <div id="ai-messages" class="flex-1 overflow-y-auto p-5 space-y-4 scroll-smooth min-h-[300px]">
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="emerald" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect></svg>
        </div>
        <div class="bg-emerald-500/5 dark:bg-emerald-500/10 p-3 rounded-2xl rounded-tl-none border border-emerald-500/10">
          <p class="text-[13px] leading-relaxed text-black/70 dark:text-white/80 font-medium">Xin chào! Tôi có thể giúp gì cho bạn về nội dung bài viết này?</p>
        </div>
      </div>
    </div>

    <!-- Input Area -->
    <div class="p-4 border-t border-black/5 dark:border-white/5 bg-black/[0.02] dark:bg-white/[0.02]">
      <div class="relative group">
        <textarea
          id="ai-input"
          rows="1"
          class="w-full text-[13px] p-4 pr-12 rounded-2xl border border-black/10 dark:border-white/10 bg-white dark:bg-black focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500/50 transition-all resize-none text-black dark:text-white placeholder:text-black/30 dark:placeholder:text-white/30"
          placeholder="Nhập câu hỏi của bạn..."
        ></textarea>
        <button
          id="ai-send"
          class="absolute right-3 bottom-3 p-2 bg-emerald-500 text-white rounded-xl hover:scale-105 active:scale-95 transition-all disabled:opacity-50 disabled:hover:scale-100"
          disabled
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg>
        </button>
      </div>
      <p class="text-[9px] text-center mt-3 text-black/20 dark:text-white/20 uppercase font-black tracking-widest">Powered by Gemini 2.5 Flash</p>
    </div>
  </div>
</div>

<script>
  const setupAI = () => {
    const trigger = document.getElementById('ai-bubble-trigger');
    const windowEl = document.getElementById('ai-window');
    const closeBtn = document.getElementById('close-ai');
    const input = document.getElementById('ai-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('ai-send') as HTMLButtonElement;
    const messages = document.getElementById('ai-messages');
    const article = document.querySelector('article');

    if (!trigger || !windowEl || !closeBtn || !input || !sendBtn || !messages) return;

    // Toggle Window
    const toggleWindow = () => {
      const isOpen = !windowEl.classList.contains('hidden');
      if (isOpen) {
        windowEl.style.opacity = '0';
        windowEl.style.transform = 'scale(0.95) translateY(10px)';
        setTimeout(() => windowEl.classList.add('hidden'), 300);
      } else {
        windowEl.classList.remove('hidden');
        requestAnimationFrame(() => {
          windowEl.style.opacity = '1';
          windowEl.style.transform = 'scale(1) translateY(0)';
        });
      }
    };

    trigger.onclick = toggleWindow;
    closeBtn.onclick = toggleWindow;

    // Auto-resize textarea
    input.oninput = () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 120) + 'px';
      sendBtn.disabled = !input.value.trim();
    };

    const addMessage = (text: string, isUser = false) => {
      const div = document.createElement('div');
      div.className = `flex gap-3 ${isUser ? 'flex-row-reverse' : ''}`;
      
      const avatar = isUser ? '' : `<div class="w-7 h-7 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect></svg></div>`;
      
      div.innerHTML = `
        ${avatar}
        <div class="${isUser ? 'bg-black dark:bg-white text-white dark:text-black' : 'bg-emerald-500/5 dark:bg-emerald-500/10 text-black/70 dark:text-white/80 border border-emerald-500/10'} p-3 rounded-2xl ${isUser ? 'rounded-tr-none' : 'rounded-tl-none'} max-w-[85%]">
          <p class="text-[13px] leading-relaxed whitespace-pre-wrap font-medium message-content"></p>
        </div>
      `;
      
      const content = div.querySelector('.message-content') as HTMLElement;
      if (isUser) {
        content.textContent = text;
      }
      
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
      return content;
    };

    const typeEffect = async (element: HTMLElement, text: string) => {
      const words = text.split(' ');
      for (let i = 0; i < words.length; i++) {
        element.textContent += words[i] + ' ';
        if (i % 3 === 0) {
            messages.scrollTop = messages.scrollHeight;
            await new Promise(r => setTimeout(r, 20));
        }
      }
    };

    const askAI = async () => {
      const question = input.value.trim();
      if (!question) return;

      input.value = '';
      input.style.height = 'auto';
      sendBtn.disabled = true;

      addMessage(question, true);

      const aiContentEl = addMessage('', false);
      aiContentEl.innerHTML = '<span class="flex gap-1 py-1"><span class="w-1 h-1 bg-emerald-500 rounded-full animate-bounce"></span><span class="w-1 h-1 bg-emerald-500 rounded-full animate-bounce [animation-delay:0.2s]"></span><span class="w-1 h-1 bg-emerald-500 rounded-full animate-bounce [animation-delay:0.4s]"></span></span>';

      try {
        const promptText = `Bạn là trợ lý AI trên blog titipi. Trả lời cực kỳ ngắn gọn, súc tích (dưới 100 từ). Dựa vào nội dung: ${article?.innerText || "N/A"}\n\nCâu hỏi: ${question}`;

        const res = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ prompt: promptText }),
        });

        // Check if response is JSON
        const contentType = res.headers.get("content-type");
        let data;
        if (contentType && contentType.includes("application/json")) {
          data = await res.json();
        } else {
          const text = await res.text();
          console.error("Server returned non-JSON response:", text);
          throw new Error("Máy chủ phản hồi không đúng định dạng. Có thể do lỗi cấu hình hoặc API Key.");
        }

        if (!res.ok) throw new Error(data?.error?.message || `Lỗi máy chủ (${res.status})`);

        const responseText = data.candidates[0].content.parts[0].text;
        aiContentEl.textContent = '';
        await typeEffect(aiContentEl, responseText);

      } catch (e: any) {
        aiContentEl.innerHTML = `<span class="text-red-500 font-bold text-[11px]">${e.message}</span>`;
      }
    };

    sendBtn.onclick = askAI;
    input.onkeydown = (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        askAI();
      }
    };
  };

  document.addEventListener("astro:page-load", setupAI);
  setupAI();
</script>

<style is:global>
  #ai-messages::-webkit-scrollbar { width: 4px; }
  #ai-messages::-webkit-scrollbar-thumb { background: rgba(16, 185, 129, 0.2); border-radius: 10px; }
  #ai-messages::-webkit-scrollbar-thumb:hover { background: rgba(16, 185, 129, 0.5); }
</style>
